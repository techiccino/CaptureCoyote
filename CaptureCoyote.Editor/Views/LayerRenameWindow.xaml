<Window x:Class="CaptureCoyote.Editor.Views.LayerRenameWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Rename Layer"
        Width="420"
        Height="214"
        MinWidth="380"
        MinHeight="196"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="#FF0C1219"
        Foreground="White">
    <Border Padding="22">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <TextBlock FontSize="20"
                       FontWeight="SemiBold"
                       Text="Rename Layer" />
            <TextBlock Grid.Row="1"
                       Margin="0,6,0,0"
                       Foreground="#A9FFFFFF"
                       Text="Choose a clearer name for this annotation layer." />
            <Border Grid.Row="2"
                    Margin="0,16,0,0"
                    Height="46"
                    Background="#FF111821"
                    BorderBrush="#FF1884C4"
                    BorderThickness="1"
                    CornerRadius="4">
                <TextBox x:Name="LayerNameTextBox"
                         Margin="12,0"
                         BorderThickness="0"
                         Background="Transparent"
                         Padding="0"
                         FontSize="15"
                         FontFamily="Segoe UI"
                         Foreground="White"
                         CaretBrush="White"
                         VerticalAlignment="Center"
                         VerticalContentAlignment="Center"
                         Text="{Binding LayerName, UpdateSourceTrigger=PropertyChanged}" />
            </Border>

            <StackPanel Grid.Row="3"
                        Margin="0,18,0,0"
                        HorizontalAlignment="Right"
                        Orientation="Horizontal">
                <Button Width="88"
                        Margin="0,0,10,0"
                        IsCancel="True"
                        Content="Cancel" />
                <Button Width="96"
                        IsDefault="True"
                        Click="SaveButton_OnClick"
                        Content="Save" />
            </StackPanel>
        </Grid>
    </Border>
</Window>
