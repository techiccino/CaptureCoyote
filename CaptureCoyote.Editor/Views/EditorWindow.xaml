                              Grid.Row="0"
                              IsExpanded="False"
                              Style="{StaticResource SidebarExpanderStyle}">
                    <Expander.Header>
                        <TextBlock FontSize="17" FontWeight="SemiBold" Text="Presets" />
                    </Expander.Header>
                    <StackPanel>
                        <ComboBox SelectedValuePath="Kind"
                                  DisplayMemberPath="DisplayName"
                                  ItemsSource="{Binding StylePresets}"
                                  SelectedValue="{Binding SelectedPresetKind}"
                                  Margin="0,0,0,8" />

                        <TextBlock Foreground="#77FFFFFF"
                                   Text="{Binding CurrentPresetDescription}"
                                   TextWrapping="Wrap" />
                    </StackPanel>
                </Expander>

                    <Expander x:Name="PropertiesExpander"
                              Grid.Row="1"
                              IsExpanded="True"
                              Style="{StaticResource SidebarExpanderStyle}">
                    <Expander.Header>
                        <TextBlock FontSize="17" FontWeight="SemiBold" Text="Properties" />
                    </Expander.Header>
                    <StackPanel>
                        <TextBlock Margin="0,0,0,4" Text="Stroke Color" />
                        <TextBox Text="{Binding StrokeColorHex, UpdateSourceTrigger=LostFocus}" />
                        <ItemsControl Margin="0,6,0,0" ItemsSource="{Binding RecentColors}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <WrapPanel />
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Button Style="{StaticResource ColorSwatchButtonStyle}"
                                            Background="{Binding Converter={StaticResource HexToBrushConverter}}"
                                            Command="{Binding DataContext.ApplyStrokePresetCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                            CommandParameter="{Binding}" />
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <TextBlock Margin="0,8,0,4" Text="Fill Color" />
                        <TextBox Text="{Binding FillColorHex, UpdateSourceTrigger=LostFocus}" />
                        <ItemsControl Margin="0,6,0,0" ItemsSource="{Binding RecentColors}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <WrapPanel />
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Button Style="{StaticResource ColorSwatchButtonStyle}"
                                            Background="{Binding Converter={StaticResource HexToBrushConverter}}"
                                            Command="{Binding DataContext.ApplyFillPresetCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                            CommandParameter="{Binding}" />
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <TextBlock Margin="0,8,0,4" Text="Thickness" />
                        <Slider Minimum="0" Maximum="14" Value="{Binding StrokeThickness}" />

                        <TextBlock Margin="0,8,0,4" Text="Opacity" />
                        <Slider Minimum="0.1" Maximum="1" Value="{Binding Opacity}" />

                        <TextBlock Margin="0,8,0,4" Text="Font Size" />
                        <Slider Minimum="10" Maximum="48" Value="{Binding FontSize}" />

                        <TextBlock Margin="0,8,0,4" Text="Pixelate Strength" />
                        <Slider Minimum="2" Maximum="28" Value="{Binding BlurStrength}" />
                    </StackPanel>
                </Expander>

                    <Expander Grid.Row="2"
                              IsExpanded="True"
                              Margin="0,0,0,10"
                              Style="{StaticResource SidebarExpanderStyle}">
                    <Expander.Header>
                        <TextBlock FontSize="17" FontWeight="SemiBold" Text="Layers" />
                    </Expander.Header>
                    <ListBox x:Name="LayersListBox"
                             Style="{StaticResource LayerListStyle}"
                             AllowDrop="True"
                             ItemContainerStyle="{StaticResource LayerListItemStyle}"
                             ItemsSource="{Binding LayerAnnotations}"
                             SelectedItem="{Binding SelectedAnnotation, Mode=TwoWay}"
                             ToolTip="Drag to reorder layers. Right-click to rename."
                             PreviewMouseLeftButtonDown="LayersListBox_OnPreviewMouseLeftButtonDown"
                             MouseMove="LayersListBox_OnMouseMove"
                             DragOver="LayersListBox_OnDragOver"
                             Drop="LayersListBox_OnDrop">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Border Background="Transparent">
                                    <Border.ContextMenu>
                                        <ContextMenu DataContext="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource Self}}">
                                            <MenuItem Header="Rename Layer"
                                                      Click="RenameLayerMenuItem_OnClick" />
                                        </ContextMenu>
                                    </Border.ContextMenu>
                                    <DockPanel LastChildFill="True">
                                        <TextBlock Margin="0,0,8,0"
                                                   VerticalAlignment="Center"
                                                   Foreground="#6DD3FC"
                                                   FontSize="12"
                                                   Text="≡" />
                                        <TextBlock FontWeight="SemiBold"
                                                   Foreground="#FFF7FAFD"
                                                   TextWrapping="NoWrap"
                                                   TextTrimming="CharacterEllipsis">
                                            <TextBlock.Text>
                                                <MultiBinding Converter="{StaticResource LayerDisplayNameConverter}">
                                                    <Binding />
                                                    <Binding RelativeSource="{RelativeSource AncestorType=Window}" Path="DataContext" />
                                                </MultiBinding>
                                            </TextBlock.Text>
                                        </TextBlock>
                                    </DockPanel>
                                </Border>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </Expander>

                    <Expander x:Name="LayerActionsExpander"
                              Grid.Row="3"
                              IsExpanded="False"
                              Margin="0"
                              Style="{StaticResource SidebarExpanderStyle}">
                    <Expander.Header>
                        <TextBlock FontSize="17" FontWeight="SemiBold" Text="Layer Actions" />
                    </Expander.Header>
                    <UniformGrid Columns="2">
                        <Button Margin="0,0,8,8"
                                Style="{StaticResource SideActionButtonStyle}"
                                Command="{Binding BringForwardCommand}"
                                Content="Forward" />
                        <Button Margin="0,0,0,8"
                                Style="{StaticResource SideActionButtonStyle}"
                                Command="{Binding SendBackwardCommand}"
                                Content="Backward" />
                        <Button Margin="0,0,8,0"
                                Style="{StaticResource SideActionButtonStyle}"
                                Command="{Binding DeleteSelectionCommand}"
                                Content="Delete" />
                        <Button Margin="0"
                                Style="{StaticResource SideActionButtonStyle}"
                                Command="{Binding ClearCropCommand}"
                                Content="Clear Crop" />
                    </UniformGrid>
                    </Expander>
                </Grid>
            </ScrollViewer>
        </Border>

        <Border Grid.Row="2"
                Grid.ColumnSpan="3"
                Margin="0,14,0,0"
                Padding="12,10"
                Background="#99111821"
                CornerRadius="14">
            <DockPanel>
                <TextBlock DockPanel.Dock="Left"
                           Foreground="#CCFFFFFF"
                           Text="{Binding StatusText}" />
                <TextBlock DockPanel.Dock="Right"
                           HorizontalAlignment="Right"
                           Foreground="#66FFFFFF"
                           Text="Shortcuts: V A R E L T Q N H B C | Ctrl+Z Ctrl+Y Ctrl+D Del | Arrows move | Shift+Arrows 10px | Ctrl++ Ctrl+- Ctrl+0" />
            </DockPanel>
        </Border>
    </Grid>
</Window>
