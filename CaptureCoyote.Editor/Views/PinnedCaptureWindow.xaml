<Window x:Class="CaptureCoyote.Editor.Views.PinnedCaptureWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Pinned Capture"
        Width="460"
        Height="320"
        MinWidth="280"
        MinHeight="200"
        Background="#FF0C1118"
        Foreground="White"
        ShowInTaskbar="False"
        Topmost="True"
        WindowStartupLocation="Manual">
    <Border Margin="12"
            Padding="14"
            Background="#FF111821"
            BorderBrush="#331884C4"
            BorderThickness="1"
            CornerRadius="18">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <DockPanel Margin="0,0,0,12">
                <StackPanel DockPanel.Dock="Left"
                            Orientation="Horizontal">
                    <Border x:Name="BrandLogoContainer"
                            Width="28"
                            Height="28"
                            Margin="0,0,10,0"
                            Padding="3"
                            Background="#1A1884C4"
                            CornerRadius="9"
                            Visibility="Collapsed">
                        <Image x:Name="BrandLogoImage" Stretch="Uniform" Visibility="Collapsed" />
                    </Border>
                    <StackPanel>
                        <TextBlock x:Name="PinnedTitleText"
                                   FontSize="16"
                                   FontWeight="SemiBold"
                                   Text="Pinned Capture" />
                        <TextBlock Foreground="#88FFFFFF"
                                   Text="Always-on-top reference window" />
                    </StackPanel>
                </StackPanel>

                <Button DockPanel.Dock="Right"
                        Width="34"
                        Height="34"
                        Padding="0"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Top"
                        Click="CloseButton_OnClick">
                    <TextBlock FontSize="16"
                               FontWeight="SemiBold"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"
                               Text="X" />
                </Button>
            </DockPanel>

            <Border Grid.Row="1"
                    Background="#FF0A1016"
                    BorderBrush="#221884C4"
                    BorderThickness="1"
                    CornerRadius="14">
                <Viewbox Stretch="Uniform">
                    <Image x:Name="PinnedImage"
                           Stretch="Uniform" />
                </Viewbox>
            </Border>
        </Grid>
    </Border>
</Window>
