<UserControl x:Class="CaptureCoyote.Editor.Controls.AnnotationCanvasControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Focusable="True">
    <UserControl.Resources>
        <Style x:Key="ZoomButtonStyle" TargetType="Button">
            <Setter Property="Width" Value="34" />
            <Setter Property="Height" Value="28" />
            <Setter Property="Margin" Value="0,0,6,0" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="Background" Value="#FF15202C" />
            <Setter Property="BorderBrush" Value="#332A3F54" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="ButtonBorder"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="10">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ButtonBorder" Property="Background" Value="#FF1A2B3A" />
                                <Setter TargetName="ButtonBorder" Property="BorderBrush" Value="#6647A8DF" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="ButtonBorder" Property="Background" Value="#FF133447" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>
    <Grid Background="Transparent">
        <Border Background="#FF11151C"
                BorderBrush="#3322303A"
                BorderThickness="1"
                CornerRadius="18"
                Padding="12">
            <Grid>
                <ScrollViewer x:Name="SurfaceScrollViewer"
                              HorizontalScrollBarVisibility="Auto"
                              VerticalScrollBarVisibility="Auto"
                              CanContentScroll="False"
                              PanningMode="Both">
                    <Grid x:Name="SurfaceScaleHost"
                          HorizontalAlignment="Left"
                          VerticalAlignment="Top">
                        <Grid.LayoutTransform>
                            <ScaleTransform x:Name="SurfaceScaleTransform"
                                            ScaleX="1"
                                            ScaleY="1" />
                        </Grid.LayoutTransform>
                        <Canvas x:Name="SurfaceCanvas"
                                Background="#FF0F141B"
                                ClipToBounds="True" />
                    </Grid>
                </ScrollViewer>

                <Border HorizontalAlignment="Right"
                        VerticalAlignment="Top"
                        Margin="10"
                        Padding="8,6"
                        Background="#D9111821"
                        BorderBrush="#331884C4"
                        BorderThickness="1"
                        CornerRadius="12">
                    <StackPanel Orientation="Horizontal">
                        <Button Style="{StaticResource ZoomButtonStyle}"
                                Click="FitZoomButtonOnClick"
                                ToolTip="Fit the capture to the editor viewport">
                            <TextBlock Text="Fit" />
                        </Button>
                        <Button Style="{StaticResource ZoomButtonStyle}"
                                Click="ZoomOutButtonOnClick"
                                ToolTip="Zoom out (Ctrl + -)">
                            <TextBlock FontSize="16" Text="-" />
                        </Button>
                        <Border MinWidth="58"
                                Height="28"
                                Margin="0,0,6,0"
                                Padding="12,0"
                                Background="#FF0F171F"
                                BorderBrush="#332A3F54"
                                BorderThickness="1"
                                CornerRadius="10">
                            <TextBlock x:Name="ZoomText"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"
                                       FontSize="12"
                                       FontWeight="SemiBold"
                                       Foreground="White"
                                       Text="100%" />
                        </Border>
                        <Button Style="{StaticResource ZoomButtonStyle}"
                                Margin="0"
                                Click="ZoomInButtonOnClick"
                                ToolTip="Zoom in (Ctrl + +)">
                            <TextBlock FontSize="16" Text="+" />
                        </Button>
                    </StackPanel>
                </Border>
            </Grid>
        </Border>

        <Border x:Name="HintBadge"
                HorizontalAlignment="Left"
                VerticalAlignment="Top"
                Margin="20"
                Padding="10,6"
                Background="#CC101418"
                BorderBrush="#331884C4"
                BorderThickness="1"
                CornerRadius="12"
                Visibility="Collapsed">
            <TextBlock x:Name="HintText"
                       Foreground="White"
                       FontSize="12"
                       FontWeight="SemiBold" />
        </Border>
    </Grid>
</UserControl>
