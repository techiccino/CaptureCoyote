<Window x:Class="CaptureCoyote.App.Views.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:viewModels="clr-namespace:CaptureCoyote.App.ViewModels"
        xmlns:coreEnums="clr-namespace:CaptureCoyote.Core.Enums;assembly=CaptureCoyote.Core"
        Title="CaptureCoyote Settings"
        Width="860"
        Height="760"
        MinWidth="760"
        MinHeight="680"
        Background="#FF0C1118"
        Foreground="White"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResize">
    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />
        <Style x:Key="SupportButtonStyle" TargetType="Button">
            <Setter Property="Padding" Value="12,8" />
            <Setter Property="Foreground" Value="#FFFF63B0" />
            <Setter Property="Background" Value="#221A0E19" />
            <Setter Property="BorderBrush" Value="#66FF63B0" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="ButtonBorder"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="12"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ButtonBorder" Property="Background" Value="#33231523" />
                                <Setter TargetName="ButtonBorder" Property="BorderBrush" Value="#88FF63B0" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="ButtonBorder" Property="Background" Value="#441A0E19" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <StackPanel>
                <StackPanel Orientation="Horizontal">
                    <Border x:Name="BrandLogoContainer"
                            Width="48"
                            Height="48"
                            Margin="0,0,14,0"
                            Padding="4"
                            Background="#1A1884C4"
                            CornerRadius="16"
                            Visibility="Collapsed">
                        <Image x:Name="BrandLogoImage" Stretch="Uniform" Visibility="Collapsed" />
                    </Border>
                    <StackPanel>
                        <TextBlock FontSize="24" FontWeight="SemiBold" Text="Settings" />
                        <TextBlock Margin="0,4,0,18" Foreground="#99FFFFFF" Text="Simple defaults that keep capture fast." />
                    </StackPanel>
                </StackPanel>

                <TextBlock Text="Default Save Folder" />
                <TextBox Margin="0,6,0,14" Text="{Binding DefaultSaveFolder}" />

                <TextBlock Text="File Naming Pattern" />
                <TextBox Margin="0,6,0,14" Text="{Binding FileNamingPattern}" />
                <TextBlock Margin="0,0,0,16" Foreground="#77FFFFFF" Text="Available tokens: {date}, {time}, {mode}, {title}" />

                <TextBlock Text="Preferred Image Format" />
                <ComboBox Margin="0,6,0,14"
                          SelectedValuePath="Content"
                          SelectedValue="{Binding PreferredImageFormat}">
                    <ComboBoxItem Content="{x:Static coreEnums:ImageFileFormat.Png}" />
                    <ComboBoxItem Content="{x:Static coreEnums:ImageFileFormat.Jpg}" />
                </ComboBox>

                <CheckBox Margin="0,0,0,10" IsChecked="{Binding AutoCopyToClipboard}" Content="Auto-copy captured image to clipboard" />
                <CheckBox Margin="0,0,0,18" IsChecked="{Binding AutoOpenEditor}" Content="Auto-open the editor after capture" />

                <TextBlock FontSize="20" FontWeight="SemiBold" Text="Startup" />
                <TextBlock Margin="0,6,0,12" Foreground="#77FFFFFF" Text="Choose whether CaptureCoyote starts with Windows, and whether a normal manual launch opens straight into the launcher or shows a short branded splash first." TextWrapping="Wrap" />
                <CheckBox Margin="0,0,0,10"
                          IsChecked="{Binding LaunchOnWindowsStartup}"
                          Content="Launch CaptureCoyote when Windows starts" />
                <TextBlock Margin="0,0,0,12"
                           Foreground="#77FFFFFF"
                           Text="Windows startup launches open quietly to the system tray so they do not interrupt your desktop."
                           TextWrapping="Wrap" />
                <CheckBox Margin="0,0,0,18"
                          IsChecked="{Binding ShowSplashScreenOnLaunch}"
                          Content="Show splash screen when launching CaptureCoyote" />

                <TextBlock FontSize="20" FontWeight="SemiBold" Text="History &amp; Cleanup" />
                <TextBlock Margin="0,6,0,12"
                           Foreground="#77FFFFFF"
                           Text="Temporary snips can stay lightweight. Saved .coyote projects and exported files are left alone, while the launcher only nudges you when old temporary history starts to pile up."
                           TextWrapping="Wrap" />
                <TextBlock Text="Show cleanup hint for temporary snips older than" />
                <ComboBox Margin="0,6,0,18"
                          DisplayMemberPath="Label"
                          SelectedValuePath="Days"
                          ItemsSource="{Binding RetentionOptions}"
                          SelectedValue="{Binding TemporarySnipRetentionDays}" />

                <TextBlock FontSize="20" FontWeight="SemiBold" Text="Editor Defaults" />
                <TextBlock Margin="0,6,0,12"
                           Foreground="#77FFFFFF"
                           Text="Pick a default annotation preset and decide whether tools should gently switch to better defaults for text, highlights, blur, and steps."
                           TextWrapping="Wrap" />

                <TextBlock Text="Default Style Preset" />
                <ComboBox Margin="0,6,0,12"
                          DisplayMemberPath="DisplayName"
                          SelectedValuePath="Kind"
                          ItemsSource="{Binding StylePresetOptions}"
                          SelectedValue="{Binding DefaultStylePreset}" />

                <CheckBox Margin="0,0,0,18"
                          IsChecked="{Binding UseToolAwareDefaults}"
                          Content="Use tool-aware defaults for text, step markers, highlight, and pixelate" />

                <TextBlock FontSize="20" FontWeight="SemiBold" Text="Hotkeys" />
                <ItemsControl Margin="0,14,0,0" ItemsSource="{Binding Hotkeys}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Margin="0,0,0,12" Padding="14" Background="#FF111821" CornerRadius="14">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="170" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock VerticalAlignment="Center" FontWeight="SemiBold" Text="{Binding Name}" />

                                    <StackPanel Grid.Column="1" Orientation="Horizontal" Margin="12,0,0,0">
                                        <TextBlock VerticalAlignment="Center" Margin="0,0,10,0" Text="Ctrl + Shift +" />
                                        <ComboBox Width="140"
                                                  DisplayMemberPath="Label"
                                                  SelectedValuePath="VirtualKey"
                                                  ItemsSource="{Binding DataContext.AvailableKeys, RelativeSource={RelativeSource AncestorType=Window}}"
                                                  SelectedValue="{Binding VirtualKey}" />
                                    </StackPanel>

                                    <TextBlock Grid.Column="2"
                                               Margin="14,0,0,0"
                                               VerticalAlignment="Center"
                                               Foreground="#77FFFFFF"
                                               Text="{Binding Mode}" />
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <TextBlock Margin="0,6,0,0" Foreground="#77FFFFFF" Text="Hotkey modifiers use Ctrl + Shift by default. The MVP keeps that modifier pair fixed and lets you change the key." />

                <TextBlock Margin="0,22,0,0" FontSize="20" FontWeight="SemiBold" Text="Diagnostics" />
                <TextBlock Margin="0,6,0,12"
                           Foreground="#77FFFFFF"
                           Text="CaptureCoyote writes local troubleshooting logs to help with startup, capture, and project-open failures."
                           TextWrapping="Wrap" />
                <Button Width="160"
                        HorizontalAlignment="Left"
                        Padding="12,8"
                        Command="{Binding OpenLogsFolderCommand}"
                        Content="Open Logs Folder" />

                <StackPanel Margin="0,22,0,0"
                            Visibility="{Binding HasSupportLink, Converter={StaticResource BooleanToVisibilityConverter}}">
                    <TextBlock FontSize="20" FontWeight="SemiBold" Text="Support" />
                    <TextBlock Margin="0,6,0,12"
                               Foreground="#77FFFFFF"
                               Text="CaptureCoyote is free to use. If it saves you time, tips help fund bug fixes, polish, and new features."
                               TextWrapping="Wrap" />
                    <Button Width="200"
                            HorizontalAlignment="Left"
                            Style="{StaticResource SupportButtonStyle}"
                            Command="{Binding OpenSupportLinkCommand}"
                            Content="Support CaptureCoyote" />
                    <TextBlock Margin="0,8,0,0"
                               Foreground="#88FFFFFF"
                               Text="Optional, never required."
                               TextWrapping="Wrap" />
                </StackPanel>
            </StackPanel>
        </ScrollViewer>

        <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,18,0,0">
            <Button Width="100" Margin="0,0,10,0" Padding="12,8" Command="{Binding CancelCommand}" Content="Cancel" />
            <Button Width="100" Padding="12,8" Command="{Binding SaveCommand}" Content="Save" />
        </StackPanel>
    </Grid>
</Window>
