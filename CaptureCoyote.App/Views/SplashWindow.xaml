<Window x:Class="CaptureCoyote.App.Views.SplashWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="CaptureCoyote"
        Width="520"
        Height="320"
        Background="Transparent"
        Foreground="White"
        AllowsTransparency="True"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        WindowStyle="None"
        WindowStartupLocation="CenterScreen">
    <Grid>
        <Border CornerRadius="26"
                Background="#F20C1118"
                BorderBrush="#441884C4"
                BorderThickness="1"
                SnapsToDevicePixels="True">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <Grid Margin="30">
                    <Ellipse Width="180"
                             Height="180"
                             HorizontalAlignment="Right"
                             VerticalAlignment="Top"
                             Margin="0,-90,-70,0"
                             Fill="#141884C4" />
                    <Ellipse Width="220"
                             Height="220"
                             HorizontalAlignment="Left"
                             VerticalAlignment="Bottom"
                             Margin="-110,0,0,-140"
                             Fill="#0C7DD3FC" />

                    <StackPanel VerticalAlignment="Center">
                        <StackPanel Orientation="Horizontal">
                            <Border x:Name="BrandLogoContainer"
                                    Width="74"
                                    Height="74"
                                    Margin="0,0,18,0"
                                    Padding="6"
                                    Background="#201884C4"
                                    CornerRadius="22"
                                    Visibility="Collapsed">
                                <Image x:Name="BrandLogoImage" Stretch="Uniform" Visibility="Collapsed" />
                            </Border>
                            <StackPanel VerticalAlignment="Center">
                                <TextBlock FontSize="34"
                                           FontWeight="SemiBold"
                                           Foreground="#FFF8FBFF"
                                           Text="CaptureCoyote" />
                                <TextBlock Margin="0,8,0,0"
                                           Foreground="#A6FFFFFF"
                                           Text="Capture -> Explain -> Save or Share" />
                            </StackPanel>
                        </StackPanel>

                        <TextBlock Margin="0,26,0,0"
                                   Foreground="#CCFFFFFF"
                                   FontSize="16"
                                   Text="Editable screenshots, ready in a moment." />
                    </StackPanel>
                </Grid>

                <StackPanel Grid.Row="1"
                            Margin="30,0,30,26">
                    <ProgressBar Height="6"
                                 IsIndeterminate="True"
                                 Background="#221884C4"
                                 BorderThickness="0"
                                 Foreground="#FF1884C4" />
                    <TextBlock Margin="0,10,0,0"
                               Foreground="#77FFFFFF"
                               Text="Launching your workspace..." />
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>
