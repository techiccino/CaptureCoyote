<Window x:Class="CaptureCoyote.App.Views.CaptureReviewWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Capture Review"
        Width="820"
        Height="640"
        Background="#FF0C1118"
        Foreground="White"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize">
    <Grid Margin="18">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0"
                    Margin="0,0,0,16"
                    Orientation="Horizontal">
            <Border x:Name="BrandLogoContainer"
                    Width="48"
                    Height="48"
                    Margin="0,0,14,0"
                    Padding="4"
                    Background="#1A1884C4"
                    CornerRadius="16"
                    Visibility="Collapsed">
                <Image x:Name="BrandLogoImage" Stretch="Uniform" Visibility="Collapsed" />
            </Border>
            <StackPanel>
                <TextBlock FontSize="22" FontWeight="SemiBold" Text="Capture Review" />
                <TextBlock Margin="0,4,0,0"
                           Foreground="#99FFFFFF"
                           Text="Finish fast: copy, save, or move into the editor." />
            </StackPanel>
        </StackPanel>

        <Border Grid.Row="1"
                Margin="0,0,0,14"
                Padding="12,10"
                Background="#99111821"
                CornerRadius="14">
            <DockPanel>
                <TextBlock Foreground="#CCFFFFFF"
                           Text="{Binding CaptureSummary}" />
                <Button DockPanel.Dock="Right"
                        Margin="12,0,0,0"
                        Padding="12,7"
                        Command="{Binding CopyDetectedTextCommand}"
                        Content="Copy Detected Text" />
            </DockPanel>
        </Border>

        <Border Grid.Row="2"
                Background="#FF111821"
                CornerRadius="18"
                Padding="14">
            <Image Source="{Binding PreviewImage}"
                   Stretch="Uniform" />
        </Border>

        <Border Grid.Row="3"
                Margin="0,16,0,0"
                Padding="12"
                Background="#FF111821"
                BorderBrush="#221884C4"
                BorderThickness="1"
                CornerRadius="14">
            <StackPanel>
                <TextBlock FontWeight="SemiBold" Text="Detected Text" />
                <TextBox Margin="0,8,0,0"
                         MinHeight="92"
                         MaxHeight="124"
                         Padding="10"
                         Background="#FF0E141C"
                         BorderBrush="#221884C4"
                         BorderThickness="1"
                         Foreground="#FFF2F6FA"
                         FontFamily="Consolas"
                         FontSize="12.5"
                         IsReadOnly="True"
                         AcceptsReturn="True"
                         Text="{Binding ExtractedTextPreview, Mode=OneWay}"
                         TextWrapping="Wrap"
                         VerticalScrollBarVisibility="Auto"
                         HorizontalScrollBarVisibility="Disabled" />
            </StackPanel>
        </Border>

        <WrapPanel Grid.Row="4"
                   Margin="0,16,0,0"
                   HorizontalAlignment="Center">
            <Button Margin="0,0,10,0" Padding="16,10" Command="{Binding CopyCommand}" Content="Copy" />
            <Button Margin="0,0,10,0" Padding="16,10" Command="{Binding QuickSaveCommand}" Content="Quick Save" />
            <Button Margin="0,0,10,0" Padding="16,10" Command="{Binding SaveAsCommand}" Content="Save As" />
            <Button Margin="0,0,10,0" Padding="16,10" Command="{Binding SaveEditableCommand}" Content="Save Editable" />
            <Button Margin="0,0,10,0" Padding="16,10" Command="{Binding OpenInEditorCommand}" Content="Open In Editor" />
            <Button Padding="16,10" Command="{Binding CancelCommand}" Content="Cancel" />
        </WrapPanel>

        <Border Grid.Row="5"
                Margin="0,16,0,0"
                Padding="12,10"
                Background="#99111821"
                CornerRadius="14">
            <TextBlock Foreground="#CCFFFFFF" Text="{Binding StatusText}" />
        </Border>
    </Grid>
</Window>
