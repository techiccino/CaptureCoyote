<Window x:Class="CaptureCoyote.App.Views.DelayCountdownWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Width="260"
        Height="220"
        WindowStyle="None"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        ShowActivated="False"
        Topmost="True"
        AllowsTransparency="True"
        Background="Transparent">
    <Border Background="#E6101418"
            BorderBrush="#661884C4"
            BorderThickness="1"
            CornerRadius="24"
            Padding="24">
        <StackPanel HorizontalAlignment="Center"
                    VerticalAlignment="Center">
            <TextBlock x:Name="CountdownValueText"
                       HorizontalAlignment="Center"
                       FontSize="82"
                       FontWeight="Bold"
                       Foreground="White"
                       Text="3" />
            <TextBlock x:Name="CountdownCaptionText"
                       Margin="0,2,0,0"
                       HorizontalAlignment="Center"
                       FontSize="14"
                       Foreground="#CCFFFFFF"
                       Text="Capturing in 3 seconds" />
            <TextBlock x:Name="CountdownHintText"
                       Margin="0,8,0,0"
                       HorizontalAlignment="Center"
                       FontSize="12"
                       Foreground="#88FFFFFF"
                       Text="Move into position before capture starts."
                       TextAlignment="Center"
                       TextWrapping="Wrap" />
        </StackPanel>
    </Border>
</Window>
